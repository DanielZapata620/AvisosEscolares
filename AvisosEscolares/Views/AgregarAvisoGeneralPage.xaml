<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.AgregarAvisoGeneralPage"
             BackgroundColor="White" Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto">

        <BoxView Grid.Row="0" Color="#2D214F" HeightRequest="60" />
        <Label Grid.Row="0" 
               Text="AGREGAR AVISO GENERAL" 
               TextColor="White" 
               FontSize="15" 
               FontAttributes="Bold"
               FontFamily="OpenSansSemiBold"
               HorizontalOptions="Center" 
               VerticalOptions="Center" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="25,30" Spacing="18">

                <Label Text="INFORMACION DEL AVISO" 
                       TextColor="Black" 
                       FontSize="17" 
                       FontAttributes="Bold" 
                       FontFamily="OpenSansSemiBold"
                       Margin="0,0,0,5"/>

                <VerticalStackLayout Spacing="5">
                    <Label Text="TITULO" TextColor="#333333" FontSize="12" FontAttributes="Bold" FontFamily="OpenSansSemiBold"/>
                    <Border Stroke="#000000" StrokeThickness="1" BackgroundColor="#F5E8E8" HeightRequest="40">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Entry Text="{Binding NuevoAvisoGeneral.Titulo}" 
                               TextColor="Black" 
                               Margin="10,0"
                               VerticalOptions="Center"
                               FontSize="14"
                               FontFamily="OpenSansSemiBold"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="MENSAJE" TextColor="#333333" FontSize="12" FontAttributes="Bold" FontFamily="OpenSansSemiBold"/>
                    <Border Stroke="#000000" StrokeThickness="1" BackgroundColor="#F5E8E8" HeightRequest="150">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Editor Text="{Binding NuevoAvisoGeneral.Mensaje}" 
                                TextColor="Black" 
                                Margin="10,5"
                                AutoSize="Disabled"
                                FontSize="14"
                                FontFamily="OpenSansSemiBold"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="FECHA DE CADUCIDAD" TextColor="#333333" FontSize="12" FontAttributes="Bold" FontFamily="OpenSansSemiBold"/>
                    <Border Stroke="#000000" StrokeThickness="1" BackgroundColor="#F5E8E8" HeightRequest="40">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <DatePicker Date="{Binding NuevoAvisoGeneral.FechaCaducidad}" 
                                    TextColor="Black" 
                                    Margin="10,0"
                                    FontSize="14"
                                    FontFamily="OpenSansSemiBold"/>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="2" Padding="25,0,25,20" Spacing="10">
            <Button Text="GUARDAR" 
                    Command="{Binding CrearAvisoGeneralCommand}"
                    BackgroundColor="#513B94" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemiBold"
                    CornerRadius="8" 
                    HeightRequest="42"
                    FontSize="12"/>

            <Button Text="CANCELAR" 
                    Command="{Binding CambiarVistaCommand}"
                    CommandParameter="ListaAvisos"
                    BackgroundColor="#513B94" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemiBold"
                    CornerRadius="8" 
                    HeightRequest="42"
                    FontSize="12"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.AgregarAvisoGeneralPage"
             Title="AgregarAvisoGeneralPage">
    <VerticalStackLayout>
        <Label Text="Titulo"/>
        <Entry Text="{Binding NuevoAvisoGeneral.Titulo}"/>
        <Label Text="Mensaje"/>
        <Editor Text="{Binding NuevoAvisoGeneral.Mensaje}" HeightRequest="100"/>
        <Label Text="Fecha de Caducidad"/>
        <DatePicker Date="{Binding NuevoAvisoGeneral.FechaCaducidad}"/>

        <Button Text="Guardar" Command="{Binding CrearAvisoGeneralCommand}"/>
    </VerticalStackLayout>
</ContentPage>
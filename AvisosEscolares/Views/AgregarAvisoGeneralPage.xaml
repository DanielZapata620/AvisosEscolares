<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.AgregarAvisoGeneralPage"
             BackgroundColor="White" Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*" BackgroundColor="#F4F7FB">
        <Grid ColumnDefinitions="Auto,*,Auto" BackgroundColor="#0F2D5E" Padding="20">
            <Label Grid.Column="1" Text="Agrega aviso general" TextColor="White" FontAttributes="Bold" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"></Label>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="10" Spacing="20">
                <Border BackgroundColor="White" Stroke="#E5EAF0" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"></RoundRectangle>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Titulo del aviso:" TextColor="#6B7A90" FontAttributes="Bold" Margin="10,0,0,0"></Label>
                        <Border>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"></RoundRectangle>
                            </Border.StrokeShape>
                            <Entry Text="{Binding NuevoAvisoGeneral.Titulo}" FontSize="13" BackgroundColor="#F4F7FB" TextColor="Black"
                           HeightRequest="45"></Entry>
                        </Border>

                        <Label Text="Contenido del aviso:"  TextColor="#6B7A90" FontAttributes="Bold" Margin="10,0,0,0"></Label>

                        <Border StrokeThickness="1" BackgroundColor="#F4F7FB" HeightRequest="180">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15"></RoundRectangle>
                            </Border.StrokeShape>
                            <Editor TextColor="Black" FontSize="13" Text="{Binding NuevoAvisoGeneral.Mensaje}"></Editor>
                        </Border>

                        <Label Text="Fecha de vencimiento:"  TextColor="#6B7A90" FontAttributes="Bold" Margin="10,0,0,0"></Label>

                        <Border StrokeThickness="1" BackgroundColor="#F4F7FB">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15"></RoundRectangle>
                            </Border.StrokeShape>
                            <DatePicker Date="{Binding NuevoAvisoGeneral.FechaCaducidad}" 
                                 TextColor="Black"  Margin="10,0" MinimumDate="2026-04-25"></DatePicker>

                        </Border>
                        <Label FontSize="14" Margin="0,20,0,20" TextColor="Red" Grid.Row="2" Text="{Binding Error}" HorizontalTextAlignment="Center"
                                HorizontalOptions="Center" LineBreakMode="WordWrap"></Label>
                        <Label FontSize="14" Margin="0,20,0,20" TextColor="Red" Grid.Row="2" Text="{Binding Error}" HorizontalTextAlignment="Center"
   HorizontalOptions="Center"
   LineBreakMode="WordWrap" 
></Label>
                    </VerticalStackLayout>


                </Border>

                <VerticalStackLayout Spacing="15" Margin="0,30,0,0">
                    <Button Text="Agregar aviso" Command="{Binding CrearAvisoGeneralCommand}"
                    BackgroundColor="#0F2D5E" TextColor="White" FontAttributes="Bold"
                    CornerRadius="15" HeightRequest="56"></Button>

                    <Button Text="Cancelar" Command="{Binding CambiarVistaCommand}" CommandParameter="avisosGeneralesMaestro" BackgroundColor="LightGray"
                    TextColor="#0F1A2B" BorderColor="#E5EAF0"
                    BorderWidth="1" CornerRadius="15" HeightRequest="60"></Button>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.AvisosPersonalesMaestro"
             Title="AvisosPersonalesMaestro" Shell.NavBarIsVisible="False">


    <Grid>

        
        <Grid RowDefinitions="Auto,Auto,*" BackgroundColor="#F4F7FB">
            <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="12" Background="#0F2D5E" Padding="10,25,10,10">
                    <Border WidthRequest="50" HeightRequest="50" BackgroundColor="#0EA5A0" Stroke="#0C7A76">
                    <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25"></RoundRectangle>
                    </Border.StrokeShape>
                    <Image Source="usuario.png" HeightRequest="30" WidthRequest="30"></Image>
                    </Border>

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                <Label Text="{Binding AlumnoSeleccionado.Nombre}" FontSize="15" FontAttributes="Bold" TextColor="White"></Label>
                <HorizontalStackLayout>
                    <Label Text="{Binding AlumnoSeleccionado.Usuario, StringFormat= Matrícula: {0}}" FontSize="12" TextColor="#70FFFFFF" Margin="0,0,10,0"></Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
            <Button Text="⟵" FontAttributes="Bold" FontSize="12" TextColor="White" BackgroundColor="#50000000" Grid.Column="2" Command="{Binding CambiarVistaCommand}" CommandParameter="listaAlumnos"></Button>
        </Grid>

        <CollectionView Grid.Row="2" ItemsSource="{Binding AvisosPersonales}" SelectionMode="None" Margin="10">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5"></LinearItemsLayout>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,6" BackgroundColor="White" Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>

                        <Border.Shadow>
                            <Shadow Brush="#20000000" Offset="0,2" Radius="5"></Shadow>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="6,*,Auto" Padding="12" ColumnSpacing="10">
                            <BoxView Grid.Column="0" WidthRequest="6" CornerRadius="3" Color="Orange">
                                    <BoxView.Triggers>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="Nuevo" >
                                            <Setter Property="Color" Value="#C63A0E"></Setter>
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="Visto" >
                                            <Setter Property="Color" Value="#8A5A0A"></Setter>
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="Leído">
                                            <Setter Property="Color" Value="Green"></Setter>
                                        </DataTrigger>
                                    </BoxView.Triggers>
                                </BoxView>

                            <VerticalStackLayout Grid.Column="1" Margin="0,-10,-15,0">
                                <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Titulo}" FontAttributes="Bold" FontSize="14" TextColor="Black" LineBreakMode="WordWrap"></Label>
                                    </Grid>

                                <Label Text="{Binding Mensaje}" FontSize="13" TextColor="Gray" LineBreakMode="WordWrap" ></Label>
                                    <Label Grid.Column="1" Text="{Binding Estado}" FontSize="11" TextColor="Orange" FontAttributes="Bold" HorizontalOptions="End">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Nuevo" >
                                                <Setter Property="TextColor" Value="#C63A0E"></Setter>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Visto" >
                                                <Setter Property="TextColor" Value="#8A5A0A"></Setter>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Leído">
                                                <Setter Property="TextColor" Value="Green"></Setter>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Label Text="{Binding FechaCaducidad, StringFormat='Vigencia: {0:dd-MM-yyyy}'}" FontSize="10" TextColor="White" FontAttributes="Bold"></Label>
                                </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
    </Grid>
</ContentPage>

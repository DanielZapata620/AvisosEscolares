<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.AvisosGeneralesMaestroPage"
             BackgroundColor="White" Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*" BackgroundColor="#F4F7FB">
        <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="12" Background="#0F2D5E" Padding="10,25,10,10">
            <Border WidthRequest="50" HeightRequest="50" BackgroundColor="#0EA5A0" Stroke="#0C7A76">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25"></RoundRectangle>
                </Border.StrokeShape>
                <Image Source="usuario.png" HeightRequest="30" WidthRequest="30"></Image>
            </Border>

            <VerticalStackLayout Grid.Column="1">
                <Label Text="Docente" FontSize="12" TextColor="#80FFFFFF"></Label>
                <Label Text="{Binding maestro.Nombre}" FontSize="15" FontAttributes="Bold" TextColor="White"></Label>
                <Label Text="Bachillerato General" FontSize="12" TextColor="#70FFFFFF"></Label>
            </VerticalStackLayout>

            <Border Grid.Column="2" WidthRequest="36" HeightRequest="36" BackgroundColor="#20FFFFFF">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"></RoundRectangle>
                </Border.StrokeShape>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LogoutCommand}"></TapGestureRecognizer>
                </Border.GestureRecognizers>

                <Image Source="logout.png" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center"></Image>
            </Border>

        </Grid>

        <Grid Grid.Row="1">
            <ScrollView>
                <VerticalStackLayout>
                    <Border Margin="5" BackgroundColor="White" Stroke="#E5EAF0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"></RoundRectangle>
                        </Border.StrokeShape>

                        <VerticalStackLayout>
                            <Grid ColumnDefinitions="auto,*,auto" BackgroundColor="#0F2D5E" Padding="15">
                                <Button Text="⟵" TextColor="White" BackgroundColor="#50000000" Command="{Binding CambiarVistaCommand}" CommandParameter="dashboardMaestro"></Button>
                                <Label Grid.Column="1" Text="GESTIÓN DE AVISOS GENERALES" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"></Label>
                                <Button Grid.Column="2" Text="➕" TextColor="White" BackgroundColor="#50000000" Command="{Binding CambiarVistaCommand}" 
                                CommandParameter="crearAvisoGeneral"></Button>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <Grid Grid.Row="2">
            <CollectionView  ItemsSource="{Binding AvisosGenerales}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" >
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"></RoundRectangle>
                            </Border.StrokeShape>

                            <VerticalStackLayout>
                                <Grid BackgroundColor="#0F2D5E" Padding="12" ColumnDefinitions="*,auto,auto">
                                    <Label Text="Comunicado general" FontAttributes="Bold" FontSize="14" TextColor="#80FFFFFF"></Label>

                                    <Border Grid.Column="1" BackgroundColor="#69c9c5" Padding="10,2" Stroke="Transparent"
                                        VerticalOptions="Start" Margin="0,0,10,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"></RoundRectangle>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding FechaCaducidad, StringFormat='Vigencia: {0:dd-MM-yyyy}'}" FontSize="10" TextColor="White" FontAttributes="Bold"></Label>
                                    </Border>
                                    <HorizontalStackLayout Grid.Column="2">
                                        <Image Source="view_icon.png" HeightRequest="15" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,0,5,0"></Image>
                                        <Label Text="{Binding CantLeidos}" FontSize="10" TextColor="Black" VerticalOptions="Center"></Label>
                                    </HorizontalStackLayout>

                                </Grid>
                                <VerticalStackLayout Padding="12" Spacing="8">
                                    <Label Text="{Binding Titulo}" FontAttributes="Bold" TextColor="Black" FontSize="15"></Label>
                                    <Label Text="{Binding Mensaje}" FontSize="13" TextColor="Gray" MaxLines="2"></Label>
                                    <Label Text="Publicado: 12/07/2026" FontSize="11" TextColor="LightGray" HorizontalOptions="End"></Label>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>

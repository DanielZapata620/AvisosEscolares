<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.AvisosGeneralesMaestroPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto, Auto, *">

        <BoxView Grid.Row="0" Color="#2D214F" HeightRequest="60" />
        <Label Grid.Row="0" 
               Text="GESTIÓN DE AVISOS GENERALES" 
               TextColor="White" 
               FontSize="15" 
               FontAttributes="Bold"
               FontFamily="OpenSansSemiBold"
               HorizontalOptions="Center" 
               VerticalOptions="Center" />

        <Grid Grid.Row="1" 
              Margin="20,15" 
              ColumnDefinitions="60, *" 
              ColumnSpacing="10">

            <Button Grid.Column="0"
                    ImageSource="back_arrow.png"
                    BackgroundColor="#513B94" 
                    CornerRadius="10"
                    HeightRequest="45"
                    Padding="0" />

            <Button Grid.Column="1"
                    Text="+  AGREGAR AVISO" 
                    TextColor="White" 
                    FontSize="12"
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemiBold"
                    BackgroundColor="#513B94" 
                    CornerRadius="10"
                    HeightRequest="45"
                    Command="{Binding CambiarVistaCommand}" 
                    CommandParameter="crearAvisoGeneral" />
        </Grid>

        <CollectionView Grid.Row="2" 
                        ItemsSource="{Binding AvisosGenerales}" 
                        SelectionMode="None" Margin="20">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="20" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate >
                <DataTemplate >
                    <Border Margin="20,20" 
                            Stroke="#333333" 
                            StrokeThickness="1" 
                            BackgroundColor="#F9EBEB">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>

                        <Grid RowDefinitions="Auto, *, Auto">

                            <BoxView Grid.Row="0" Color="#2D214F" HeightRequest="40" />
                            <Label Grid.Row="0" 
                                   Text="{Binding Titulo}" 
                                   TextColor="White" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemiBold"
                                   VerticalOptions="Center" 
                                   Margin="15,0" />

                            <VerticalStackLayout Grid.Row="1" Padding="15" Spacing="12">
                                <Label Text="{Binding Mensaje}" 
                                       TextColor="Black" 
                                       FontSize="12" 
                                       FontFamily="OpenSansSemiBold"
                                       LineBreakMode="WordWrap" />

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" 
                                           Text="{Binding FechaCaducidad, StringFormat='AVISO VIGENTE HASTA EL {0:dd-MM-yyyy}'}" 
                                           FontSize="9" 
                                           TextColor="Black" 
                                           FontFamily="OpenSansSemiBold"
                                           VerticalOptions="Center"/>

                                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                        <Image Source="view_icon.png" HeightRequest="13" />
                                        <Label Text="{Binding CantLeidos}" 
                                               FontSize="10" 
                                               TextColor="Black" 
                                               FontFamily="OpenSansSemiBold"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </VerticalStackLayout>

                            <Grid Grid.Row="2" HeightRequest="40" ColumnDefinitions="*, *">
                                <BoxView Grid.ColumnSpan="2" Color="#2D214F" />
                                <BoxView Grid.Column="0" HorizontalOptions="End" WidthRequest="1" BackgroundColor="Black" Margin="0,8" />

                                <Label Grid.Column="0" Text="EDITAR" TextColor="White" 
                                       FontSize="11" FontAttributes="Bold" FontFamily="OpenSansSemiBold"
                                       HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditarAvisoCommand}" 
                                                              CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <Label Grid.Column="1" Text="ELIMINAR" TextColor="White" 
                                       FontSize="11" FontAttributes="Bold" FontFamily="OpenSansSemiBold"
                                       HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminarAvisoCommand}" 
                                                              CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>

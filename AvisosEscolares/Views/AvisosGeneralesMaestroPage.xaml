<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.AvisosGeneralesMaestroPage"
             Title="AvisosGeneralesMaestroPage">
  
        <StackLayout Grid.Row="0"  Padding="10">
            <Label Text="Avisos Generales" FontSize="Large" VerticalOptions="Center"/>
            <Button Text="Agregar Aviso" Command="{Binding CambiarVistaCommand}" CommandParameter="crearAvisoGeneral" />
        
        <ScrollView>
            <CollectionView Grid.Row="1"  ItemsSource="{Binding AvisosGenerales}" Margin="10">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        
                            <StackLayout Orientation="Vertical" Padding="10">
                                <Label Text="{Binding Titulo}" FontSize="Medium" FontAttributes="Bold"/>
                                <Label Text="{Binding Mensaje}" FontSize="Small"/>
                                <Label Text="{Binding CantLeidos}"></Label>
                                <Label Text="{Binding FechaCaducidad, StringFormat='Vence el: {0:dd/MM/yyyy}'}" FontSize="Small" TextColor="Gray"/>
                            </StackLayout>
                        
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>
    </StackLayout>


</ContentPage>
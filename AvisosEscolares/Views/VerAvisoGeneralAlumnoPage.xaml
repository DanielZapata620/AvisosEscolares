<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.VerAvisoGeneralAlumnoPage"
             Title="VerAvisoGeneralAlumnoPage" Shell.NavBarIsVisible="False" BackgroundColor="WhiteSmoke">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Margin="10">
            <Border Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F2D5E" Offset="0.0"></GradientStop>
                        <GradientStop Color="#1A4280" Offset="1.0"></GradientStop>
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout >
                    <Button Text="Atras" Command="{Binding Source={RelativeSource AncestorType={x:Type Shell}}, Path=BindingContext.VerDashboardAlumnoCommand}" CommandParameter="General" BackgroundColor="#18376e" FontAttributes="Bold" TextColor="White" HorizontalOptions="Start"></Button>
                    <Label Margin="0,-10,0,0" Text="COMUNICADO OFICIAL" FontSize="12" FontAttributes="Bold" TextColor="#A0AFBF" HorizontalTextAlignment="Center"></Label>
                    <Label Text="{Binding AvisoGeneralAlumnoSeleccionado.Titulo}" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"></Label>
                    <Label Text="{Binding AvisoGeneralAlumnoSeleccionado.Estado}" FontSize="11" TextColor="Orange" Opacity="1" FontAttributes="Bold" Grid.Column="2" HorizontalOptions="Start" VerticalOptions="Center"></Label>
                </VerticalStackLayout>
            </Border>


            <Border BackgroundColor="White" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"></RoundRectangle>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="6"></Shadow>
                </Border.Shadow>

                <Grid ColumnDefinitions="*,*" RowDefinitions="auto,*" RowSpacing="10">

                    <VerticalStackLayout>
                        <Label Text="Institución" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Label Text="CETIS No. 12" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"></Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Fecha Lectura" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Label Text="{Binding AvisoGeneralAlumnoSeleccionado.FechaLeido}" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"></Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1">
                        <Label Text="Caduca" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Label Text="{Binding AvisoGeneralAlumnoSeleccionado.FechaCaducidad}" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"></Label>
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <Border BackgroundColor="White" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"></RoundRectangle>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="10"></Shadow>
                </Border.Shadow>

                <VerticalStackLayout Spacing="10">

                    <Label Text="Comunicado" FontSize="17" FontAttributes="Bold" TextColor="#A0AFBF"></Label>

                    <Label Text="{Binding AvisoGeneralAlumnoSeleccionado.Mensaje}"
                           FontSize="15"
                           TextColor="Black"
                           LineHeight="1.4"></Label>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
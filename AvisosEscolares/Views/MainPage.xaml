<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.MainPage"
             BackgroundColor="Navy"
             Shell.NavBarIsVisible="False">


    <Grid RowDefinitions="*, auto, auto">
        <Border Background="#8052A2B4" ZIndex="1" IsVisible="{Binding isLoading}">
            <ActivityIndicator Margin="10" IsVisible="{Binding isLoading}" IsRunning="True"></ActivityIndicator>
        </Border>
        <AbsoluteLayout>
            <BoxView Color="#0EA5A0"
               BackgroundColor="Transparent"
               Opacity="0.15"
               CornerRadius="140"
               AbsoluteLayout.LayoutBounds="1.1,-0.1,280,280"
               AbsoluteLayout.LayoutFlags="PositionProportional">
            </BoxView>

            <BoxView Color="#0EA5A0"
               Background="Transparent"
               Opacity="0.08"
               CornerRadius="90"
               AbsoluteLayout.LayoutBounds="-0.2,0.8,180,180"
               AbsoluteLayout.LayoutFlags="PositionProportional">
            </BoxView>

            <BoxView Color="#F05E2B" Opacity="0.12" CornerRadius="60"
               BackgroundColor="Transparent"
               AbsoluteLayout.LayoutBounds="-0.1,0.4,120,120"
               AbsoluteLayout.LayoutFlags="PositionProportional">
            </BoxView>
        </AbsoluteLayout>

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" Spacing="30" Padding="28,60,28,100">

                <VerticalStackLayout>
                    <Border WidthRequest="80" HeightRequest="80" Stroke="Transparent" Margin="10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"></RoundRectangle>
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#18c7c1" Offset="0"></GradientStop>
                                <GradientStop Color="#0e8f8a" Offset="1"></GradientStop>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Image Source="colegio.png" 
                               WidthRequest="60" HeightRequest="60" HorizontalOptions="Center"
                               VerticalOptions="Center">
                        </Image>
                    </Border>

                    <Label Text="ITESRC" FontSize="25" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"></Label>

                    <Label Text="Sistema Escolar Integral" FontSize="15" TextColor="#80FFFFFF" HorizontalOptions="Center"></Label>
                </VerticalStackLayout>


                <VerticalStackLayout Spacing="5">
                    <Label Text="MATRÍCULA" FontSize="12" FontAttributes="Bold" TextColor="#80FFFFFF"></Label>
                    <Entry Placeholder="Ej. 2024-123" TextColor="White" Margin="0" 
                           PlaceholderColor="#40FFFFFF"
                           HeightRequest="50" BackgroundColor="#14FFFFFF" Text="{Binding LoginDTO.Usuario}">
                    </Entry>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="CONTRASEÑA" FontSize="12" FontAttributes="Bold" TextColor="#80FFFFFF"></Label>
                    <Entry IsPassword="True" Placeholder="••••••••" TextColor="White" 
                           PlaceholderColor="#40FFFFFF" HeightRequest="50"
                           BackgroundColor="#14FFFFFF" Text="{Binding LoginDTO.Contrasena}">
                    </Entry>
                </VerticalStackLayout>

                <Label Grid.Row="2" Text="{Binding Error}" HorizontalTextAlignment="Center"
    HorizontalOptions="Center"
    LineBreakMode="WordWrap" FontSize="15"
TextColor="#90FFFFFF" ></Label>


                <Button Margin="0,10,0,0" Text="Iniciar Sesión" HeightRequest="50" CornerRadius="15" 
                        FontAttributes="Bold" 
                        BackgroundColor="#0EA5A0"
                        TextColor="White" Command="{Binding LoginCommand}">
                </Button>

            </VerticalStackLayout>
        </ScrollView>

        <Label Grid.Row="2" Text="© Designed by: Alfredo Mata and Daniel Zapata" FontSize="15"
         TextColor="#40FFFFFF" HorizontalOptions="Center"></Label>
    </Grid>


    

</ContentPage>

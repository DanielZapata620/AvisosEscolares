<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.VerAvisoPersonalAlumnoPage"
             Title="VerAvisoPersonalAlumnoPage">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Margin="10">
            <Border Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F2D5E" Offset="0.0"/>
                        <GradientStop Color="#1A4280" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout>
                    <Button Text="Atras" Command="{Binding Source={RelativeSource AncestorType={x:Type Shell}}, Path=BindingContext.IrInicioCommand}" BackgroundColor="#18376e" FontAttributes="Bold" TextColor="White" HorizontalOptions="Start"></Button>
                    <Label Text="Trabajo pendiente-Calculo Diferencial"  FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"></Label>
                    <Label Text="Nuevo" FontSize="11" TextColor="Orange" Opacity="1" FontAttributes="Bold" Grid.Column="2" HorizontalOptions="Start" VerticalOptions="Center"></Label>
                </VerticalStackLayout>
            </Border>


            <Border BackgroundColor="White" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="6"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="*,*" RowDefinitions="auto,*" RowSpacing="10">

                    <VerticalStackLayout>
                        <Label Text="Maestro:" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Label Text="Miguel Ángel Torres" FontSize="12" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"></Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Enviado:" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Label Text="12/04/2025" FontSize="12" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"></Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1">
                        <Label Text="Recibido:" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Label Text="18/04/2025" FontSize="12" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"></Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                        <Label Text="Leido:" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Label Text="18/04/2025" FontSize="12" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"></Label>
                    </VerticalStackLayout>

                </Grid>
                
                
                
                
            </Border>

            <Border BackgroundColor="White" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"></RoundRectangle>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="10"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="10">

                    <Label Text="Contenido del aviso" FontSize="17" FontAttributes="Bold" TextColor="#A0AFBF"></Label>

                    <Label Text="Estimado Juan, te recuerdo que tienes pendiente la entrega del ejercicio de derivadas del capítulo 4. Es necesario que resuelvas los ejercicios del 1 al 20 del libro de texto y los presentes de manera clara. Favor de enviar o traer tu tarea antes del viernes 18 de abril sin falta, de lo contrario afectará tu calificación parcial."
                        FontSize="15" TextColor="Black"></Label>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
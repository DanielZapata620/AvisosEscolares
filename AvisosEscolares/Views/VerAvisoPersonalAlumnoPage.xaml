<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosEscolares.Views.VerAvisoPersonalAlumnoPage"
             Title="VerAvisoPersonalAlumnoPage" Shell.NavBarIsVisible="False" BackgroundColor="WhiteSmoke">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Margin="10">
            <Border Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F2D5E" Offset="0.0"/>
                        <GradientStop Color="#1A4280" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout>
                    <Button Text="Atras" Command="{Binding Source={RelativeSource AncestorType={x:Type Shell}}, Path=BindingContext.VerDashboardAlumnoCommand}" CommandParameter="Personal" BackgroundColor="#18376e"  FontAttributes="Bold" TextColor="White" HorizontalOptions="Start"></Button>
                    <Label Margin="0,-20,0,0" Text="AVISO PERSONAL" FontSize="12" FontAttributes="Bold" TextColor="#A0AFBF" HorizontalTextAlignment="Center"></Label>
                    <Label Text="{Binding AvisoPersonalSeleccionadoAlumno.Titulo}"  FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"></Label>
                    <Label Text="{Binding AvisoPersonalSeleccionadoAlumno.Estado}" FontSize="11" TextColor="Orange" Opacity="1" FontAttributes="Bold" Grid.Column="2" HorizontalOptions="Start" VerticalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding AvisoPersonalSeleccionadoAlumno.Estado}" Value="Nuevo" >
                                <Setter Property="TextColor" Value="#C63A0E"></Setter>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding AvisoPersonalSeleccionadoAlumno.Estado}" Value="Recibido" >
                                <Setter Property="TextColor" Value="#8A5A0A"></Setter>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding AvisoPersonalSeleccionadoAlumno.Estado}" Value="Leído">
                                <Setter Property="TextColor" Value="Green"></Setter>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>
            </Border>


            <Border BackgroundColor="White" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="6"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="*,*" RowDefinitions="auto,*" RowSpacing="10">

                    <VerticalStackLayout>
                        <Label Text="Maestro:" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Label Text="{Binding AvisoPersonalSeleccionadoAlumno.Maestro}" FontSize="12" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"></Label>
                    </VerticalStackLayout>
                                    

                    <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                        <Label Text="Leido:" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Label Text="{Binding AvisoPersonalSeleccionadoAlumno.FechaLeido, StringFormat='{0:dd MMM yyyy, HH:mmm}'}" FontSize="12" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"></Label>
                    </VerticalStackLayout>

                </Grid>




            </Border>

            <Border BackgroundColor="White" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"></RoundRectangle>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="10"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="10">

                    <Label Text="Contenido del aviso" FontSize="17" FontAttributes="Bold" TextColor="#A0AFBF"></Label>

                    <Label Text="{Binding AvisoPersonalSeleccionadoAlumno.Mensaje}"
                        FontSize="15" TextColor="Black"></Label>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>